{
  "name": "savehydroo",
  "version": "1.0.0",
  "description": "Smart Water Blending and Monitoring System with Wokwi Simulation",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "http-server frontend -p 3000 -c-1",
